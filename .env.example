# =============================================================================
# ABC Company Astro Demo — Environment Variables
# =============================================================================
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# NEVER commit real secrets (AWS keys, tokens) to git.
# For GitHub Actions continuous deployment, add the AWS_* values as
# repository Secrets (Settings → Secrets and variables → Actions).
# =============================================================================

# -----------------------------------------------------------------------------
# Public site settings (safe to expose in the browser / build output)
# Prefix with PUBLIC_ so Astro can inject them into client-side code.
# -----------------------------------------------------------------------------

# Canonical URL of the deployed site (no trailing slash).
# Local:        http://localhost:4321
# S3 website:   http://your-bucket-name.s3-website-us-east-1.amazonaws.com
# CloudFront:   https://d1234abcd.cloudfront.net
# Custom domain:https://www.abccompany.example
PUBLIC_SITE_URL=http://localhost:4321

# Display name used in the UI and meta tags
PUBLIC_COMPANY_NAME=ABC Company

# Contact email shown on the Contact page
PUBLIC_CONTACT_EMAIL=hello@abccompany.example

# Optional: Google Analytics / other measurement ID (leave blank to disable)
PUBLIC_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# AWS deployment settings
# Used by GitHub Actions (.github/workflows/deploy.yml) — store these as
# GitHub Secrets, not in a committed .env file.
# -----------------------------------------------------------------------------

# AWS IAM credentials for the deploy user (least-privilege: S3 + optional CF)
AWS_ACCESS_KEY_ID=AKIA................................
AWS_SECRET_ACCESS_KEY=........................................

# AWS region where the S3 bucket lives (example: us-east-1, ap-southeast-1)
AWS_REGION=us-east-1

# Target S3 bucket name (must already exist and allow static website hosting
# or be fronted by CloudFront)
AWS_S3_BUCKET=abc-company-astro-demo

# Optional: CloudFront distribution ID. If set, the workflow invalidates the
# cache after each deploy so visitors see the latest build immediately.
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# Optional: custom S3 object prefix (leave blank to deploy to bucket root)
AWS_S3_PREFIX=
