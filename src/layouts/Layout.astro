---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const companyName = import.meta.env.PUBLIC_COMPANY_NAME || 'ABC Company';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || 'http://localhost:4321';

const {
  title = `${companyName} — Digital products that feel human`,
  description = `${companyName} designs and builds calm, reliable web experiences for growing teams.`,
} = Astro.props;

const fullTitle = title.includes(companyName) ? title : `${title} · ${companyName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
