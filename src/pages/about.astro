---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamMember from '../components/TeamMember.astro';
import CTA from '../components/CTA.astro';

const companyName = import.meta.env.PUBLIC_COMPANY_NAME || 'ABC Company';

const team = [
  {
    name: 'Avery Chen',
    role: 'Founder & Design Lead',
    bio: 'Shapes brand systems and page hierarchy so students can see how layout decisions feel in the browser.',
  },
  {
    name: 'Blake Okonkwo',
    role: 'Astro Engineer',
    bio: 'Builds components, MDX collections, and the static build that lands in the S3 bucket.',
  },
  {
    name: 'Casey Rivera',
    role: 'DevOps Mentor',
    bio: 'Writes the GitHub Actions workflow and explains IAM, buckets, and cache invalidation.',
  },
];
---

<BaseLayout
  title={`About ${companyName}`}
  description={`Meet the fictioned team behind ${companyName} and learn why this Astro demo exists.`}
>
  <section class="page-hero section">
    <div class="container">
      <p class="section__eyebrow">About</p>
      <h1 class="page-hero__title">{companyName}</h1>
      <p class="section__lead">
        {companyName} is a made-up product studio created for classroom demos. Use it to practice
        component composition, content authoring in MDX, and shipping static HTML to the cloud.
      </p>
    </div>
  </section>

  <section class="section story">
    <div class="container story__grid">
      <div>
        <h2>Our story (fictioned on purpose)</h2>
        <p>
          In this timeline, {companyName} started as three friends teaching weekend workshops on
          modern static sites. They needed one shared example that was small enough to understand
          in an afternoon, but complete enough to show real deployment.
        </p>
        <p>
          That example became this repository: Astro for structure, MDX for articles, npm for the
          toolchain, and GitHub Actions for continuous deployment to Amazon S3.
        </p>
      </div>
      <aside class="story__aside" aria-label="Learning goals">
        <h3>Student goals</h3>
        <ul>
          <li>Read an Astro layout and follow the slot pattern</li>
          <li>Author an MDX post with frontmatter</li>
          <li>Run <code>npm install</code>, <code>npm run dev</code>, and <code>npm run build</code></li>
          <li>Map GitHub Secrets to AWS credentials for S3 deploys</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section__eyebrow">People</p>
      <h2 class="section__title">The demo team</h2>
      <div class="team-grid">
        {
          team.map((member) => (
            <TeamMember name={member.name} role={member.role} bio={member.bio} />
          ))
        }
      </div>
    </div>
  </section>

  <CTA
    title="Curious how the pages are built?"
    text="Browse /services for component demos, then open /blog for MDX articles."
    ctaLabel="Explore services"
    ctaHref="/services/"
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
  }

  .page-hero__title {
    font-size: clamp(2.6rem, 7vw, 4.4rem);
    max-width: 12ch;
    margin-bottom: 0.75rem;
  }

  .story {
    padding-top: 0;
  }

  .story__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .story__aside {
    padding: 1.35rem 1.4rem;
    background: rgba(15, 118, 110, 0.08);
    border-left: 3px solid var(--color-sea);
  }

  .story__aside h3 {
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
  }

  .story__aside ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-ink-soft);
  }

  .story__aside li + li {
    margin-top: 0.45rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 2.5rem);
    margin-top: var(--space-lg);
  }

  @media (max-width: 860px) {
    .story__grid,
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
