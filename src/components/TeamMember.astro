---
interface Props {
  name: string;
  role: string;
  bio: string;
}

const { name, role, bio } = Astro.props;
const initials = name
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<article class="member">
  <div class="member__avatar" aria-hidden="true">{initials}</div>
  <h3 class="member__name">{name}</h3>
  <p class="member__role">{role}</p>
  <p class="member__bio">{bio}</p>
</article>

<style>
  .member {
    animation: fade-up 0.7s var(--ease-out) both;
  }

  .member__avatar {
    display: grid;
    place-items: center;
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1rem;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--color-sea-glow), var(--color-sea-deep));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .member__name {
    margin: 0 0 0.2rem;
    font-size: 1.15rem;
  }

  .member__role {
    margin: 0 0 0.65rem;
    color: var(--color-sea);
    font-weight: 700;
    font-size: 0.88rem;
  }

  .member__bio {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
