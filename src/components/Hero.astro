---
interface Props {
  companyName?: string;
  headline?: string;
  supporting?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
}

const companyName = Astro.props.companyName || import.meta.env.PUBLIC_COMPANY_NAME || 'ABC Company';
const {
  headline = 'Websites that feel clear, calm, and ready to ship.',
  supporting = 'We help growing teams turn ideas into fast static sites with Astro, MDX content, and dependable deployment.',
  primaryCta = { href: '/contact/', label: 'Start a project' },
  secondaryCta = { href: '/services/', label: 'See our services' },
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-brand">
  <div class="hero__media" aria-hidden="true">
    <div class="hero__glow hero__glow--sea"></div>
    <div class="hero__glow hero__glow--coral"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="hero__content container">
    <p class="hero__brand" id="hero-brand">{companyName}</p>
    <span class="hero__rule" aria-hidden="true"></span>
    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__supporting">{supporting}</p>
    <div class="hero__actions">
      <a class="btn btn--primary" href={primaryCta.href}>{primaryCta.label}</a>
      <a class="btn btn--ghost" href={secondaryCta.href}>{secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: grid;
    align-items: end;
    overflow: hidden;
    color: #fff;
    background: linear-gradient(160deg, #0b1a22 0%, #12303a 45%, #0f4a45 100%);
  }

  .hero__media {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.55;
    animation: drift 7s ease-in-out infinite alternate;
  }

  .hero__glow--sea {
    width: min(55vw, 28rem);
    height: min(55vw, 28rem);
    right: -6%;
    top: 12%;
    background: radial-gradient(circle, rgba(20, 184, 166, 0.55), transparent 70%);
  }

  .hero__glow--coral {
    width: min(40vw, 20rem);
    height: min(40vw, 20rem);
    left: 8%;
    bottom: 8%;
    background: radial-gradient(circle, rgba(232, 93, 76, 0.4), transparent 70%);
    animation-delay: 1.2s;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse at 40% 60%, #000 20%, transparent 75%);
    opacity: 0.45;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: clamp(4rem, 12vh, 7rem) clamp(3.5rem, 10vh, 6rem);
    max-width: 48rem;
    animation: fade-up 0.8s var(--ease-out) both;
  }

  .hero__brand {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 9vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
  }

  .hero__rule {
    display: block;
    width: 4.5rem;
    height: 3px;
    margin: 1.1rem 0 1.35rem;
    background: var(--color-sea-glow);
    transform-origin: left center;
    animation: line-grow 0.9s var(--ease-out) 0.25s both;
  }

  .hero__headline {
    margin: 0 0 1rem;
    color: #fff;
    font-size: clamp(1.45rem, 3.2vw, 2.15rem);
    font-weight: 600;
    max-width: 22ch;
  }

  .hero__supporting {
    margin: 0 0 1.75rem;
    max-width: 36rem;
    color: rgba(232, 240, 244, 0.82);
    font-size: 1.08rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero :global(.btn--ghost) {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }

  .hero :global(.btn--ghost:hover) {
    border-color: #fff;
    color: #fff;
  }
</style>
